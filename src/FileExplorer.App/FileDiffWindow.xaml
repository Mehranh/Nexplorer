<Window x:Class="FileExplorer.App.FileDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:FileExplorer.App.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="File Diff" Width="1100" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13">
    <DockPanel>
        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                Padding="10,7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="FileCompare" Width="14" Height="14"
                                            Margin="0,0,8,0" Foreground="#E2C04B" VerticalAlignment="Center"/>
                <TextBlock x:Name="HeaderLabel" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBg}"
                Padding="10,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatsLabel" FontSize="10"
                           Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Close" Click="Close_Click" Width="70"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                        BorderBrush="{DynamicResource BorderBrush}" Padding="4,3"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Side-by-side diff panels -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left file -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Padding="8,3" Background="#2D1515">
                    <TextBlock x:Name="LeftLabel" FontSize="10" Foreground="#F14C4C" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <ctrl:DiffRichTextBox x:Name="LeftDiff" SharedScrollBar="{Binding ElementName=MiddleScroll}"/>
            </DockPanel>

            <!-- Middle scrollbar -->
            <ScrollBar x:Name="MiddleScroll" Grid.Column="1" Orientation="Vertical" Width="14"/>

            <!-- Right file -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Padding="8,3" Background="#152D15">
                    <TextBlock x:Name="RightLabel" FontSize="10" Foreground="#4EC94E" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <ctrl:DiffRichTextBox x:Name="RightDiff" SharedScrollBar="{Binding ElementName=MiddleScroll}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
