<Window x:Class="FileExplorer.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileExplorer.App.ViewModels"
        xmlns:settings="clr-namespace:FileExplorer.App.Services.Settings"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:svc="clr-namespace:FileExplorer.App.Services"
        Title="Settings" Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13">

    <!-- ═══ Local resources ═══ -->
    <Window.Resources>
        <!-- Enum sources for ComboBoxes -->
        <ObjectDataProvider x:Key="StartupBehaviorValues"   MethodName="GetValues" ObjectType="{x:Type settings:StartupBehavior}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:StartupBehavior"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="DefaultViewModeValues"   MethodName="GetValues" ObjectType="{x:Type settings:DefaultViewMode}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:DefaultViewMode"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ClickModeValues"         MethodName="GetValues" ObjectType="{x:Type settings:ClickMode}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:ClickMode"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="DefaultSortModeValues"   MethodName="GetValues" ObjectType="{x:Type settings:DefaultSortMode}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:DefaultSortMode"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ConflictResolutionValues" MethodName="GetValues" ObjectType="{x:Type svc:ConflictResolution}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="svc:ConflictResolution"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="DefaultShellValues"      MethodName="GetValues" ObjectType="{x:Type settings:DefaultShell}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:DefaultShell"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="AppThemeValues"          MethodName="GetValues" ObjectType="{x:Type settings:AppTheme}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:AppTheme"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="LogLevelValues"          MethodName="GetValues" ObjectType="{x:Type settings:LogLevel}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="settings:LogLevel"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Category key → Visibility converter (inline) -->
        <local:CategoryKeyToVisibilityConverter x:Key="CategoryVisibilityConverter"
            xmlns:local="clr-namespace:FileExplorer.App.Converters"/>

        <!-- ── SettingLabel style ── -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── SettingCheck style ── -->
        <Style x:Key="SettingCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <!-- ── SettingCombo style ── -->
        <Style x:Key="SettingCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- ── SettingTextBox style ── -->
        <Style x:Key="SettingTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- ── SearchBox style (placeholder text) ── -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextFg}"/>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Text" Value=""/>
                        <Condition Property="IsFocused" Value="False"/>
                    </MultiTrigger.Conditions>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Button styles ── -->
        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SettingsButton}">
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Window.InputBindings>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left sidebar ═══ -->
        <DockPanel Grid.Column="0" Background="{DynamicResource StatusBg}">
            <!-- Search box -->
            <TextBox DockPanel.Dock="Top" Margin="8,12,8,8"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Search settings…"
                     Style="{StaticResource SearchBoxStyle}"/>

            <!-- Category list -->
            <ListBox ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource TextFg}" Margin="0,4,0,0"
                     KeyboardNavigation.TabNavigation="Cycle">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="12,8">
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>

        <!-- Separator -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

        <!-- ═══ Right content area ═══ -->
        <DockPanel Grid.Column="2">

            <!-- Bottom toolbar -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource PaneBg}" Padding="12,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Import" Command="{Binding ImportSettingsCommand}"
                            Style="{StaticResource SettingsButton}" Margin="0,0,8,0"/>
                    <Button Content="Export" Command="{Binding ExportSettingsCommand}"
                            Style="{StaticResource SettingsButton}" Margin="0,0,8,0"/>
                    <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}"
                            Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </Border>

            <!-- Scrollable settings panels -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                <Grid>
                    <!-- ─── General ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=general}">
                        <TextBlock Text="General" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Startup Behavior" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding StartupBehavior}"
                                  ItemsSource="{Binding Source={StaticResource StartupBehaviorValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <TextBlock Text="Default View Mode" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding DefaultViewMode}"
                                  ItemsSource="{Binding Source={StaticResource DefaultViewModeValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <TextBlock Text="Click Mode" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding ClickMode}"
                                  ItemsSource="{Binding Source={StaticResource ClickModeValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <TextBlock Text="Default Sort" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding DefaultSortMode}"
                                  ItemsSource="{Binding Source={StaticResource DefaultSortModeValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <CheckBox Content="Confirm before delete" IsChecked="{Binding ConfirmBeforeDelete}"
                                  Style="{StaticResource SettingCheck}" Margin="0,12,0,0"/>
                        <CheckBox Content="Show hidden files"     IsChecked="{Binding ShowHiddenFiles}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Show system files"     IsChecked="{Binding ShowSystemFiles}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Text="Language" Style="{StaticResource SettingLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120" Style="{StaticResource SettingTextBox}"/>
                            <TextBlock Text="⚠ Requires restart" Foreground="#E8A838" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ─── Performance ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=performance}">
                        <TextBlock Text="Performance" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <CheckBox Content="Enable aggressive caching"  IsChecked="{Binding EnableAggressiveCaching}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Text="Max icon cache size (MB)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding MaxIconCacheSizeMb, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>

                        <TextBlock Text="Max preview cache size (MB)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding MaxPreviewCacheSizeMb, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>

                        <TextBlock Text="Max concurrent file operations" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding MaxConcurrentFileOperations, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>

                        <CheckBox Content="Enable USN Journal monitoring  ⚠ Requires restart"
                                  IsChecked="{Binding EnableUsnJournalMonitoring}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Text="Enumeration batch size" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding EnumerationBatchSize, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>

                        <TextBlock Text="Throttle background metadata (ms)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding ThrottleBackgroundMetadataMs, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>
                    </StackPanel>

                    <!-- ─── File Operations ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=fileOperations}">
                        <TextBlock Text="File Operations" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Default conflict resolution" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding DefaultConflictResolution}"
                                  ItemsSource="{Binding Source={StaticResource ConflictResolutionValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <CheckBox Content="Enable copy queue"    IsChecked="{Binding EnableCopyQueue}"
                                  Style="{StaticResource SettingCheck}" Margin="0,12,0,0"/>
                        <CheckBox Content="Enable pause/resume"  IsChecked="{Binding EnablePauseResume}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Move to Recycle Bin by default" IsChecked="{Binding MoveToRecycleBin}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Use long path support" IsChecked="{Binding UseLongPathSupport}"
                                  Style="{StaticResource SettingCheck}"/>
                    </StackPanel>

                    <!-- ─── Command Runner ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=commandRunner}">
                        <TextBlock Text="Command Runner" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Default shell" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding DefaultShell}"
                                  ItemsSource="{Binding Source={StaticResource DefaultShellValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <CheckBox Content="Enable command history" IsChecked="{Binding EnableCommandHistory}"
                                  Style="{StaticResource SettingCheck}" Margin="0,12,0,0"/>

                        <TextBlock Text="Max history entries" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding MaxHistoryEntries, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Style="{StaticResource SettingTextBox}"/>

                        <CheckBox Content="Enable fuzzy history search" IsChecked="{Binding EnableFuzzyHistorySearch}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Enable auto-suggestions"     IsChecked="{Binding EnableAutoSuggestions}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Enable command templates"    IsChecked="{Binding EnableCommandTemplates}"
                                  Style="{StaticResource SettingCheck}"/>

                        <Button Content="Clear Command History" Command="{Binding ClearCommandHistoryCommand}"
                                Style="{StaticResource DangerButton}" Margin="0,16,0,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- ─── Appearance ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=appearance}">
                        <TextBlock Text="Appearance" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource SettingLabel}">
                            <Run Text="Theme"/>
                            <Run Text="  ⚠ Requires restart" Foreground="#E8A838" FontSize="11"/>
                        </TextBlock>
                        <ComboBox SelectedItem="{Binding Theme}"
                                  ItemsSource="{Binding Source={StaticResource AppThemeValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <TextBlock Text="Accent color (#hex)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Style="{StaticResource SettingTextBox}"/>

                        <CheckBox Content="Compact density mode" IsChecked="{Binding CompactDensityMode}"
                                  Style="{StaticResource SettingCheck}" Margin="0,12,0,0"/>
                        <CheckBox Content="Show preview pane by default" IsChecked="{Binding ShowPreviewPane}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Show folder tree"   IsChecked="{Binding ShowFolderTree}"
                                  Style="{StaticResource SettingCheck}"/>
                        <CheckBox Content="Enable animations"  IsChecked="{Binding EnableAnimations}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Style="{StaticResource SettingLabel}">
                            <Run Text="Command line font family"/>
                            <Run Text="  ⚠ Requires restart" Foreground="#E8A838" FontSize="11"/>
                        </TextBlock>
                        <TextBox Text="{Binding CommandLineFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Style="{StaticResource SettingTextBox}"/>

                        <TextBlock Text="Command line font size" Style="{StaticResource SettingLabel}"/>
                        <TextBox Text="{Binding CommandLineFontSize, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" Style="{StaticResource SettingTextBox}"/>
                    </StackPanel>

                    <!-- ─── Keyboard ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=keyboard}">
                        <TextBlock Text="Keyboard &amp; Shortcuts" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <CheckBox Content="Enable Far-style keybindings" IsChecked="{Binding EnableFarStyleKeybindings}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Text="Custom shortcut overrides are stored in the settings file. Edit the JSON directly to rebind keys."
                                   TextWrapping="Wrap" Foreground="{DynamicResource SubTextFg}" Margin="0,16,0,0" FontSize="12"/>
                    </StackPanel>

                    <!-- ─── Advanced ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=advanced}">
                        <TextBlock Text="Advanced" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <CheckBox Content="Enable diagnostics logging" IsChecked="{Binding EnableDiagnosticsLogging}"
                                  Style="{StaticResource SettingCheck}"/>

                        <TextBlock Text="Log level" Style="{StaticResource SettingLabel}"/>
                        <ComboBox SelectedItem="{Binding LogLevel}"
                                  ItemsSource="{Binding Source={StaticResource LogLevelValues}}"
                                  Style="{StaticResource SettingCombo}"/>

                        <Button Content="Open Log Folder" Command="{Binding OpenLogFolderCommand}"
                                Style="{StaticResource SettingsButton}" Margin="0,8,0,0"
                                HorizontalAlignment="Left"/>

                        <CheckBox Content="Enable crash reporting" IsChecked="{Binding EnableCrashReporting}"
                                  Style="{StaticResource SettingCheck}" Margin="0,16,0,0"/>
                        <CheckBox Content="Enable experimental features" IsChecked="{Binding EnableExperimentalFeatures}"
                                  Style="{StaticResource SettingCheck}"/>
                    </StackPanel>

                    <!-- ─── About ─── -->
                    <StackPanel Visibility="{Binding SelectedCategory.Key, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=about}">
                        <TextBlock Text="About" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="N" FontSize="28" FontWeight="Bold" Foreground="#1E88E5"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Background="Transparent"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Nexplorer" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock FontSize="13" Foreground="{DynamicResource SubTextFg}">
                                    <Run Text="Version"/>
                                    <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <Border Background="{DynamicResource InputBg}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubTextFg}" FontSize="12" LineHeight="20">
                                Nexplorer is a free, open-source dual-pane file explorer for Windows — 100% developed by AI (GitHub Copilot).
                            </TextBlock>
                        </Border>

                        <TextBlock Text="© 2026 Nexplorer" Foreground="{DynamicResource SubTextFg}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
