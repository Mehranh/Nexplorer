<Window x:Class="FileExplorer.App.QuickEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Quick Edit" Width="820" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13">
    <DockPanel>
        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                Padding="10,7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="FileEditOutline"
                                            Width="14" Height="14" Margin="0,0,8,0"
                                            Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                <TextBlock x:Name="FileNameLabel" DockPanel.Dock="Left" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="ModifiedIndicator" DockPanel.Dock="Left" Text=" ●" FontSize="12"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="EncodingLabel" FontSize="10" Margin="0,0,12,0"
                               Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LineInfoLabel" FontSize="10"
                               Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Bottom button bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBg}"
                Padding="10,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <CheckBox x:Name="WordWrapCheck" Content="Word Wrap" IsChecked="False"
                              Foreground="{DynamicResource TextFg}" VerticalAlignment="Center" Margin="0,0,16,0"
                              Checked="WordWrapCheck_Changed" Unchecked="WordWrapCheck_Changed"/>
                    <CheckBox x:Name="ShowLineNumbers" Content="Line Numbers" IsChecked="True"
                              Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                              Checked="ShowLineNumbers_Changed" Unchecked="ShowLineNumbers_Changed"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reload" Click="Reload_Click" Width="80" Margin="0,0,8,0"
                            Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                            BorderBrush="{DynamicResource BorderBrush}" Padding="4,3"/>
                    <Button x:Name="SaveButton" Content="Save  (Ctrl+S)" Click="Save_Click" Width="110" Margin="0,0,8,0"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            BorderBrush="{DynamicResource AccentBrush}" Padding="4,3"/>
                    <Button Content="Close" Click="Close_Click" Width="70"
                            Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                            BorderBrush="{DynamicResource BorderBrush}" Padding="4,3"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Editor (created in code-behind to avoid XAML namespace issues) -->
        <ContentControl x:Name="EditorHost"/>
    </DockPanel>
</Window>
