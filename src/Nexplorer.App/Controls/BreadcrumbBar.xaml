<UserControl x:Class="Nexplorer.App.Controls.BreadcrumbBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             x:Name="Root"
             Background="Transparent"
             Focusable="False"
             FocusVisualStyle="{x:Null}">
    <UserControl.Resources>

        <!-- Segment button: text-only chip, hover underline, click to navigate. -->
        <Style x:Key="BreadcrumbSegment" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextFg}"/>
            <Setter Property="Padding"     Value="6,2"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- '›' separator between segments -->
        <Style x:Key="BreadcrumbSeparator" TargetType="TextBlock">
            <Setter Property="Text" Value="›"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,0,0,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="SegmentTemplate">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BreadcrumbSegment}"
                        Content="{Binding Display}"
                        Tag="{Binding}"
                        Click="Segment_Click"
                        AutomationProperties.Name="{Binding AutomationName}"
                        ToolTip="{Binding FullPath}"/>
                <TextBlock Style="{StaticResource BreadcrumbSeparator}"
                           Visibility="{Binding ShowSeparator, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!-- We host both the breadcrumb strip and the editable TextBox in a Grid so
         we can swap them in-place without reflowing the parent layout. -->
    <Grid>
        <!-- Breadcrumb mode (default) -->
        <Border x:Name="BreadcrumbHost"
                Background="Transparent"
                MouseLeftButtonDown="Host_MouseLeftButtonDown"
                Visibility="Visible">
            <DockPanel LastChildFill="True">
                <iconPacks:PackIconMaterial DockPanel.Dock="Left"
                                            Kind="Folder"
                                            Width="13" Height="13"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource SubTextFg}"
                                            Margin="2,0,8,0"/>

                <!-- Right-aligned edit affordance: pencil icon, also hit-tested for click-to-edit -->
                <Button DockPanel.Dock="Right"
                        x:Name="EditButton"
                        Click="EditButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="6,2" Cursor="Hand"
                        ToolTip="Edit path (Ctrl+L)"
                        AutomationProperties.Name="Edit path">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                <iconPacks:PackIconMaterial Kind="PencilOutline" Width="11" Height="11"
                                                            Foreground="{DynamicResource SubTextFg}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Segments. ItemsControl.ItemsSource bound in code-behind. -->
                <ItemsControl x:Name="SegmentsItems"
                              ItemTemplate="{StaticResource SegmentTemplate}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Edit mode -->
        <TextBox x:Name="PathBox"
                 Visibility="Collapsed"
                 Background="Transparent" BorderThickness="0"
                 FontFamily="Cascadia Code,Consolas,Segoe UI" FontSize="12"
                 VerticalContentAlignment="Center"
                 AutomationProperties.Name="Path"
                 KeyDown="PathBox_KeyDown"
                 LostKeyboardFocus="PathBox_LostKeyboardFocus"/>
    </Grid>
</UserControl>
