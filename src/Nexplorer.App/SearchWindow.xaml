<Window x:Class="Nexplorer.App.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Advanced Search" Width="700" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Search query + root -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Search:" VerticalAlignment="Center"/>
            <TextBox x:Name="QueryBox" Grid.Column="1" FontSize="14"
                     ToolTip="Substring match by default. Use wildcards like *.txt or report?.docx, or enable 'Use Regex' for full regex."/>
        </Grid>
        <Grid Grid.Row="0" Margin="0,36,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="In:" VerticalAlignment="Center"/>
            <TextBox x:Name="RootBox" Grid.Column="1"/>
        </Grid>

        <!-- Row 1: Options -->
        <WrapPanel Grid.Row="1" Margin="0,12,0,0">
            <CheckBox x:Name="RecursiveCheck" Content="Search subfolders" IsChecked="True"
                      Foreground="{DynamicResource TextFg}" Margin="0,0,16,0"/>
            <CheckBox x:Name="RegexCheck" Content="Use Regex" Foreground="{DynamicResource TextFg}" Margin="0,0,16,0"/>
        </WrapPanel>

        <!-- Row 2: Size / Date filters -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Size (KB):" VerticalAlignment="Center"/>
            <TextBox x:Name="MinSizeBox" Grid.Column="1" ToolTip="Minimum size (KB)"/>
            <TextBlock Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="MaxSizeBox" Grid.Column="3" ToolTip="Maximum size (KB)"/>

            <TextBlock Grid.Column="5" Text="Modified:" VerticalAlignment="Center"/>
            <DatePicker x:Name="DateAfterPicker" Grid.Column="6" Background="{DynamicResource TreeBg}" Foreground="{DynamicResource TextFg}"/>
            <TextBlock Grid.Column="7" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <DatePicker x:Name="DateBeforePicker" Grid.Column="8" Background="{DynamicResource TreeBg}" Foreground="{DynamicResource TextFg}"/>
        </Grid>

        <!-- Row 3: Results -->
        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" Padding="8,4"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="ResultsHeader" Text="Results" Foreground="{DynamicResource SubTextFg}"
                           FontWeight="SemiBold" FontSize="11"/>
            </Border>
            <ListView x:Name="ResultsList" Background="{DynamicResource PaneBg}" BorderThickness="0"
                      MouseDoubleClick="ResultsList_DoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Path" Width="340" DisplayMemberBinding="{Binding DirectoryName}"/>
                        <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding Length, StringFormat='{}{0:n0}'}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!-- Row 4: Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="{DynamicResource SubTextFg}" Margin="0,0,16,0"/>
            <Button x:Name="SearchButton" Content="Search" Width="90" Height="30" Click="Search_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
            <Button Content="Close" Width="80" Height="30" Click="Close_Click"
                    Background="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextFg}" BorderThickness="0"
                    Cursor="Hand" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
