<Window x:Class="Nexplorer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Nexplorer.App.ViewModels"
        xmlns:svc="clr-namespace:Nexplorer.App.Services"
        xmlns:ctrl="clr-namespace:Nexplorer.App.Controls"
        xmlns:conv="clr-namespace:Nexplorer.App.Converters"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Nexplorer" Height="840" Width="1520"
        Icon="nexplorer.ico"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13"
        WindowStyle="SingleBorderWindow"
        AutomationProperties.Name="Nexplorer file explorer"
        KeyboardNavigation.TabNavigation="Cycle"
        KeyboardNavigation.DirectionalNavigation="Continue">

    <Window.Resources>
        <CubicEase x:Key="ToastEase" EasingMode="EaseOut"/>

        <Style x:Key="PaneContainer" TargetType="Border">
            <Setter Property="Background"     Value="{DynamicResource PaneBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius"    Value="{DynamicResource PaneCornerRadius}"/>
            <Setter Property="Margin"          Value="{DynamicResource PaneMargin}"/>
        </Style>

        <!-- Shared context menu for file panes -->
        <ContextMenu x:Key="PaneContextMenu"
                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">

            <!-- ── Top-level: the 8 most-used commands ─────────────────────── -->
            <MenuItem Header="Open"           Command="{Binding OpenSelectedCommand}"     InputGestureText="Enter">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="OpenInApp" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Open With…"     Command="{Binding OpenWithCommand}">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ApplicationEditOutline" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Cut"            Command="{Binding CutSelectedCommand}"     InputGestureText="Ctrl+X">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ContentCut" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy"           Command="{Binding CopySelectedCommand}"    InputGestureText="Ctrl+C">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ContentCopy" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Paste"          Command="{Binding PasteCommand}"           InputGestureText="Ctrl+V">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ContentPaste" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Rename"         Command="{Binding BeginRenameCommand}"     InputGestureText="F2">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="RenameBox" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Delete"         Command="{Binding DeleteSelectedCommand}"  InputGestureText="Del">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Delete" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>

            <!-- ── Submenu: Send to (cross-pane + clipboard variants) ─────── -->
            <Separator/>
            <MenuItem Header="Send to"        IsEnabled="{Binding HasSelection}">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Send" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
                <MenuItem Header="Copy to other pane"  Click="CopyToOtherPane_Click"  InputGestureText="F5"/>
                <MenuItem Header="Move to other pane"  Click="MoveToOtherPane_Click"  InputGestureText="F6"/>
                <Separator/>
                <MenuItem Header="Copy as path"        Command="{Binding CopyPathCommand}" InputGestureText="Ctrl+Shift+C"/>
            </MenuItem>

            <!-- ── Submenu: Compare ───────────────────────────────────────── -->
            <MenuItem Header="Compare">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="FileCompare" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
                <MenuItem Header="Quick edit"          Click="QuickEdit_Click"   InputGestureText="F3"/>
                <MenuItem Header="Diff files (L ↔ R)"  Click="DiffFiles_Click"   InputGestureText="Ctrl+D"/>
            </MenuItem>

            <!-- ── Submenu: New ───────────────────────────────────────────── -->
            <MenuItem Header="New">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
                <MenuItem Header="New folder"  Command="{Binding NewFolderCommand}" InputGestureText="F7"/>
                <MenuItem Header="New file"    Command="{Binding NewFileCommand}"   InputGestureText="Ctrl+N"/>
            </MenuItem>

            <!-- ── Submenu: Tools (advanced, lower-frequency operations) ──── -->
            <MenuItem Header="Tools">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Tools" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
                <MenuItem Header="Batch rename…"       Click="BatchRename_Click"         InputGestureText="Ctrl+M" IsEnabled="{Binding HasSelection}"/>
                <MenuItem Header="Open terminal here"  Command="{Binding OpenTerminalHereCommand}"/>
                <MenuItem Header="Git history"         Click="GitHistory_Click"          InputGestureText="Ctrl+G"/>
                <MenuItem Header="Space radar"         Click="SpaceRadar_Click"          InputGestureText="Ctrl+Shift+R"/>
                <Separator/>
                <MenuItem Header="Go to other pane's folder"  Click="GoToOtherPaneFolder_Click"/>
            </MenuItem>

            <!-- ── View / selection / metadata ───────────────────────────── -->
            <Separator/>
            <MenuItem Header="Search…"       Click="Search_Click"                       InputGestureText="Ctrl+F">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Magnify" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Filter current folder…" Command="{Binding ActivePane.ToggleFilterCommand}">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Filter" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Toggle preview" Command="{Binding TogglePreviewCommand}"   InputGestureText="F8"/>
            <Separator/>
            <MenuItem Header="Select all"     Command="{Binding SelectAllCommand}"       InputGestureText="Ctrl+A"/>
            <MenuItem Header="Invert selection" Command="{Binding InvertSelectionCommand}"/>
            <Separator/>
            <MenuItem Header="Add to favorites" Click="AddToFavorites_Click" IsEnabled="{Binding HasSelection}">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="Star" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Properties"     Command="{Binding OpenPropertiesCommand}"  InputGestureText="Alt+Enter">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="InformationOutline" Width="12" Height="12" Background="Transparent" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Tab item template -->
        <DataTemplate x:Key="PaneTabTemplate" DataType="{x:Type vm:PaneTabViewModel}">
            <Border MinWidth="70" MaxWidth="200"
                    BorderThickness="0,0,0,2"
                    MouseLeftButtonDown="TabItem_MouseDown"
                    Tag="{Binding}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"  Value="{DynamicResource HeaderBg}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background"  Value="{DynamicResource PaneBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ActivePaneBorder}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Tag="{Binding}" Click="TabClose_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="16" Height="16" Padding="2"
                            Margin="0,0,4,0" VerticalAlignment="Center" ToolTip="Close Tab"
                            AutomationProperties.Name="Close tab">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <iconPacks:PackIconMaterial Kind="Close" Width="8" Height="8">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                    </Button>
                    <TextBlock Padding="10,6,4,6" VerticalAlignment="Center"
                               Text="{Binding Header}" TextTrimming="CharacterEllipsis" FontSize="11.5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- ═══ VIEW MODE ITEM TEMPLATES ═══ -->

        <!-- Large Icons item -->
        <DataTemplate x:Key="LargeIconItemTemplate">
            <StackPanel Width="90" Margin="4" HorizontalAlignment="Center">
                <Image Source="{Binding ShellIcon}" Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" Margin="0,4,0,4"/>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap" MaxHeight="34" TextAlignment="Center"
                           HorizontalAlignment="Center" FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Small Icons item -->
        <DataTemplate x:Key="SmallIconItemTemplate">
            <StackPanel Orientation="Horizontal" Width="180" Margin="2,1">
                <Image Source="{Binding ShellIcon}" Width="16" Height="16"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" Margin="2,0,4,0"/>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" FontSize="11.5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- List mode item -->
        <DataTemplate x:Key="ListItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <Image Source="{Binding ShellIcon}" Width="16" Height="16"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" Margin="2,0,4,0"/>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Tiles item -->
        <DataTemplate x:Key="TilesItemTemplate">
            <StackPanel Orientation="Horizontal" Width="240" Margin="2">
                <Image Source="{Binding ShellIcon}" Width="32" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" Margin="2,0,6,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="{DynamicResource SubTextFg}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SizeDisplay}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="Text" Value="Folder"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- View mode context menu (shared template) -->
        <ContextMenu x:Key="ViewModeMenu">
            <MenuItem Header="Details" Click="ViewMode_Click" Tag="Details">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ViewList" Width="12" Height="12" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Large Icons" Click="ViewMode_Click" Tag="LargeIcons">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ViewGrid" Width="12" Height="12" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Small Icons" Click="ViewMode_Click" Tag="SmallIcons">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ViewModule" Width="12" Height="12" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="List" Click="ViewMode_Click" Tag="List">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ViewSequential" Width="12" Height="12" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Tiles" Click="ViewMode_Click" Tag="Tiles">
                <MenuItem.Icon><iconPacks:PackIconMaterial Kind="ViewDashboard" Width="12" Height="12" Foreground="{DynamicResource TextFg}"/></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- F-key toolbar button -->
        <Style x:Key="FKeyButton" TargetType="Button">
            <Setter Property="Background"     Value="{DynamicResource FKeyBg}"/>
            <Setter Property="Foreground"     Value="{DynamicResource TextFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource FKeyBorder}"/>
            <Setter Property="Padding"        Value="8,3"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="MinWidth"       Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
    <DockPanel>

        <!-- ══════════════ BOTTOM: F-KEY TOOLBAR (Alt-hold overlay) ══════════════ -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBg}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding IsFKeyOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <UniformGrid Rows="1" Margin="2,1">
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F3">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F3 "/><Run Text="View"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F4">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F4 "/><Run Text="Edit"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F5">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F5 "/><Run Text="Copy"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F6">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F6 "/><Run Text="Move"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F7">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F7 "/><Run Text="NewDir"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F8">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F8 "/><Run Text="Preview"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="F9">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F9 "/><Run Text="Search"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="Rename">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="F2 "/><Run Text="Rename"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="Compare">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="Cmp "/><Run Text="Compare"/></TextBlock>
                </Button>
                <Button Style="{StaticResource FKeyButton}" Click="FKey_Click" Tag="BatchRename">
                    <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource SubTextFg}" Text="M-R "/><Run Text="Batch"/></TextBlock>
                </Button>
            </UniformGrid>
        </Border>

        <!-- ══════════════ MAIN CONTENT ══════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="100"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ COL 0: FOLDER TREE ═══ -->
            <Border Grid.Column="0" Background="{DynamicResource TreeBg}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                    CornerRadius="{DynamicResource PaneCornerRadius}" Margin="{DynamicResource PaneMargin}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,5">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource NavButton}"
                                    ToolTip="Settings (Ctrl+,)" Click="SettingsButton_Click"
                                    Width="24" Height="24" Margin="4,0,0,0">
                                <iconPacks:PackIconMaterial Kind="Cog" Width="13" Height="13"/>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FileTree" Width="13" Height="13"
                                                            Foreground="{DynamicResource SubTextFg}"
                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Explorer" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TreeView x:Name="FolderTreeView"
                              ItemsSource="{Binding FolderTree.Roots}"
                              SelectedItemChanged="FolderTree_SelectedItemChanged"
                              Background="{DynamicResource TreeBg}" FontSize="12.5">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FolderTreeNodeViewModel}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="1,2">
                                    <Image Source="{Binding Icon}" Width="18" Height="18"
                                           Margin="0,0,5,0" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                <Setter Property="FontSize" Value="12.5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="FontSize" Value="10.5"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
                                                        <Setter Property="Margin" Value="0,8,0,2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ═══ COL 2: PANES + TERMINAL ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="280" MinHeight="120"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: DUAL PANES -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="{Binding IsDualPane, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=5}"/>
                        <ColumnDefinition Width="{Binding IsDualPane, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=*}"/>
                    </Grid.ColumnDefinitions>

                    <!-- ════ LEFT PANE ════ -->
                    <Border Grid.Column="0" x:Name="LeftPaneBorder"
                            PreviewMouseDown="LeftPaneBorder_PreviewMouseDown">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource PaneContainer}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LeftPane.IsActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource ActivePaneBorder}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <!-- Tab strip -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource StatusBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <DockPanel DataContext="{Binding LeftTabs}">
                                    <Button DockPanel.Dock="Right" Command="{Binding AddTabCommand}"
                                            Style="{StaticResource NavButton}" Width="28" Height="26"
                                            ToolTip="New Tab" Margin="2,0"
                                            AutomationProperties.Name="New tab in left pane">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="10" Height="10"/>
                                    </Button>
                                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="PaneTabStrip_PreviewMouseWheel">
                                        <ItemsControl x:Name="LeftTabStrip" Tag="Left"
                                                      ItemsSource="{Binding Tabs}" ItemTemplate="{StaticResource PaneTabTemplate}"
                                                      AllowDrop="True"
                                                      PreviewMouseLeftButtonDown="PaneTabStrip_PreviewMouseLeftButtonDown"
                                                      PreviewMouseMove="PaneTabStrip_PreviewMouseMove"
                                                      DragOver="PaneTabStrip_DragOver"
                                                      Drop="PaneTabStrip_Drop">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                            <!-- Nav bar -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,3">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,4,0">
                                        <Button Command="{Binding LeftPane.NavigateBackCommand}" Style="{StaticResource NavButton}" ToolTip="Back" AutomationProperties.Name="Back">
                                            <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding LeftPane.NavigateForwardCommand}" Style="{StaticResource NavButton}" ToolTip="Forward" AutomationProperties.Name="Forward">
                                            <iconPacks:PackIconMaterial Kind="ChevronRight" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding LeftPane.NavigateUpCommand}" Style="{StaticResource NavButton}" ToolTip="Up" AutomationProperties.Name="Up one level">
                                            <iconPacks:PackIconMaterial Kind="ArrowUp" Width="13" Height="13"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button x:Name="LeftViewModeButton" Style="{StaticResource NavButton}" ToolTip="View Mode" Click="LeftViewModeButton_Click" AutomationProperties.Name="View mode">
                                            <iconPacks:PackIconMaterial Kind="ViewList" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding LeftPane.ToggleFilterCommand}" Style="{StaticResource NavButton}" ToolTip="Filter current folder (loaded items only)" AutomationProperties.Name="Toggle filter">
                                            <iconPacks:PackIconMaterial Kind="Filter" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding LeftPane.TogglePreviewCommand}" Style="{StaticResource NavButton}" ToolTip="Preview (F8)" AutomationProperties.Name="Toggle preview pane">
                                            <iconPacks:PackIconMaterial Kind="Eye" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding LeftPane.NavigateCommand}" Style="{StaticResource NavButton}" ToolTip="Refresh" Margin="4,0,0,0" AutomationProperties.Name="Refresh">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding ToggleDualPaneCommand}" Style="{StaticResource NavButton}"
                                                ToolTip="Split / unsplit (Ctrl+\)"
                                                AutomationProperties.Name="Toggle dual pane">
                                            <iconPacks:PackIconMaterial Kind="ViewSplitVertical" Width="13" Height="13"/>
                                        </Button>
                                    </StackPanel>
                                    <ctrl:BreadcrumbBar Path="{Binding LeftPane.CurrentPath, Mode=TwoWay}"
                                                        NavigateCommand="{Binding LeftPane.GoToPathCommand}"
                                                        VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <!-- Status bar -->
                            <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8,3">
                                <TextBlock Text="{Binding LeftPane.StatusText}"
                                           Foreground="{DynamicResource SubTextFg}" FontSize="11"/>
                            </Border>
                            <!-- File list + preview split -->
                            <Grid>
                                <Grid.Resources>
                                    <conv:BindingProxy x:Key="LeftDcProxy" Data="{Binding}"/>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="{Binding Data.LeftPane.ShowPreview, Source={StaticResource LeftDcProxy}, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=4}"/>
                                    <ColumnDefinition Width="{Binding Data.LeftPane.ShowPreview, Source={StaticResource LeftDcProxy}, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=320}"
                                                      MinWidth="{Binding Data.LeftPane.ShowPreview, Source={StaticResource LeftDcProxy}, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter=200}"/>
                                </Grid.ColumnDefinitions>
                                <ListView x:Name="LeftList" Grid.Column="0"
                                          Visibility="{Binding LeftPane.ViewMode, Converter={StaticResource ViewModeToVisibilityConverter}, ConverterParameter=Details}"
                                          ItemsSource="{Binding LeftPane.ItemsView}"
                                          SelectedItem="{Binding LeftPane.SelectedItem, Mode=TwoWay}"
                                          Tag="{Binding LeftPane}" SelectionMode="Extended"
                                          ContextMenu="{StaticResource PaneContextMenu}"
                                          Background="{DynamicResource PaneBg}" BorderThickness="0"
                                          MouseDoubleClick="LeftList_MouseDoubleClick"
                                          PreviewMouseLeftButtonUp="LeftList_PreviewMouseLeftButtonUp"
                                          GotFocus="LeftList_GotFocus"
                                          SelectionChanged="LeftList_SelectionChanged"
                                          ContextMenuOpening="LeftList_ContextMenuOpening"
                                          GridViewColumnHeader.Click="PaneList_ColumnHeaderClick"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="PaneList_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="PaneList_PreviewMouseMove"
                                          DragOver="PaneList_DragOver"
                                          Drop="PaneList_Drop"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          KeyboardNavigation.TabNavigation="Once"
                                          KeyboardNavigation.DirectionalNavigation="Contained">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="32">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding ShellIcon}" Width="20" Height="20"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" Width="260">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <StackPanel Orientation="Vertical"
                                                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            </DataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                                    <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding RelativeSubPath}" FontSize="10"
                                                                       Foreground="{DynamicResource SubTextFg}"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,-2,0,0"
                                                                       ToolTip="{Binding FullPath}"
                                                                       Visibility="{Binding HasRelativeSubPath, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                            <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                     Background="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource AccentBrush}"
                                                                     BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                                                     FontSize="12.5" Padding="2,0" Margin="-3,0"
                                                                     IsVisibleChanged="RenameBox_IsVisibleChanged"
                                                                     PreviewKeyDown="RenameBox_PreviewKeyDown"
                                                                     LostFocus="RenameBox_LostFocus"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Type" Width="70">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="11"
                                                                   Foreground="{DynamicResource SubTextFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Size" Width="80">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                                   Foreground="{DynamicResource SubTextFg}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Modified" Width="140">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding LastWriteTimeLocal, StringFormat={}{0:yyyy-MM-dd  HH:mm}}"
                                                                   FontSize="11" Foreground="{DynamicResource SubTextFg}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <!-- Icon/List/Tiles view (left) -->
                                <ListBox x:Name="LeftIconList" Grid.Column="0"
                                         Visibility="{Binding LeftPane.ViewMode, Converter={StaticResource ViewModeNotEqualToVisibilityConverter}, ConverterParameter=Details}"
                                         ItemsSource="{Binding LeftPane.ItemsView}"
                                         SelectedItem="{Binding LeftPane.SelectedItem, Mode=TwoWay}"
                                         Tag="{Binding LeftPane}" SelectionMode="Extended"
                                         ContextMenu="{StaticResource PaneContextMenu}"
                                         Background="{DynamicResource PaneBg}" BorderThickness="0"
                                         MouseDoubleClick="LeftList_MouseDoubleClick"
                                         PreviewMouseLeftButtonUp="LeftList_PreviewMouseLeftButtonUp"
                                         GotFocus="LeftList_GotFocus"
                                         SelectionChanged="LeftIconList_SelectionChanged"
                                         ContextMenuOpening="LeftList_ContextMenuOpening"
                                         AllowDrop="True"
                                         PreviewMouseLeftButtonDown="PaneList_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="PaneList_PreviewMouseMove"
                                         DragOver="PaneList_DragOver"
                                         Drop="PaneList_Drop"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="ItemTemplate" Value="{StaticResource LargeIconItemTemplate}"/>
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LeftPane.ViewMode}" Value="SmallIcons">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource SmallIconItemTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LeftPane.ViewMode}" Value="List">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource ListItemTemplate}"/>
                                                    <Setter Property="ItemsPanel">
                                                        <Setter.Value>
                                                            <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LeftPane.ViewMode}" Value="Tiles">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource TilesItemTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                </ListBox>
                                <!-- Preview pane (left) -->
                                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              Visibility="{Binding LeftPane.ShowPreview, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Background="{DynamicResource BorderBrush}"/>
                                <Border Grid.Column="2"
                                        Visibility="{Binding LeftPane.ShowPreview, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0">
                                    <DockPanel>
                                        <!-- Quick-action row at the bottom of the drawer -->
                                        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,1,0,0" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Reveal" Click="PreviewReveal_Click" Tag="Left"
                                                        Style="{StaticResource NavButton}" Width="Auto" Padding="8,3"
                                                        ToolTip="Reveal in Windows Explorer"
                                                        AutomationProperties.Name="Reveal in Windows Explorer"/>
                                                <Button Content="Properties" Click="PreviewProperties_Click" Tag="Left"
                                                        Style="{StaticResource NavButton}" Width="Auto" Padding="8,3" Margin="4,0,0,0"
                                                        ToolTip="Show native Windows properties dialog"
                                                        AutomationProperties.Name="Open native properties"/>
                                            </StackPanel>
                                        </Border>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="LeftPreviewPanel" Margin="10"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <!-- Floating filter overlay (left) — anchored top-right of the file list,
                                     does not reflow content; click outside / Esc to dismiss. -->
                                <Border Grid.Column="0" Tag="{Binding LeftPane}"
                                        Visibility="{Binding LeftPane.IsFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,8,12,0" Padding="8,5"
                                        Background="{DynamicResource HeaderBg}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Effect="{StaticResource DialogShadow}">
                                    <DockPanel MinWidth="260">
                                        <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="Magnify" Width="12" Height="12"
                                                                    Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button DockPanel.Dock="Right" Command="{Binding LeftPane.ClearFilterCommand}"
                                                Style="{StaticResource NavButton}" Width="20" Height="20" ToolTip="Clear filter (Esc)"
                                                AutomationProperties.Name="Clear filter">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="9" Height="9"/>
                                        </Button>
                                        <TextBox x:Name="LeftFilterBox"
                                                 Text="{Binding LeftPane.FilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontFamily="Cascadia Code,Consolas" FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 IsVisibleChanged="FilterBox_IsVisibleChanged"
                                                 PreviewKeyDown="FilterBox_PreviewKeyDown"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- ════ RIGHT PANE ════ -->
                    <Border Grid.Column="2" x:Name="RightPaneBorder"
                            PreviewMouseDown="RightPaneBorder_PreviewMouseDown">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource PaneContainer}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RightPane.IsActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource ActivePaneBorder}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <!-- Tab strip -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource StatusBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <DockPanel DataContext="{Binding RightTabs}">
                                    <Button DockPanel.Dock="Right" Command="{Binding AddTabCommand}"
                                            Style="{StaticResource NavButton}" Width="28" Height="26"
                                            ToolTip="New Tab" Margin="2,0"
                                            AutomationProperties.Name="New tab in right pane">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="10" Height="10"/>
                                    </Button>
                                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="PaneTabStrip_PreviewMouseWheel">
                                        <ItemsControl x:Name="RightTabStrip" Tag="Right"
                                                      ItemsSource="{Binding Tabs}" ItemTemplate="{StaticResource PaneTabTemplate}"
                                                      AllowDrop="True"
                                                      PreviewMouseLeftButtonDown="PaneTabStrip_PreviewMouseLeftButtonDown"
                                                      PreviewMouseMove="PaneTabStrip_PreviewMouseMove"
                                                      DragOver="PaneTabStrip_DragOver"
                                                      Drop="PaneTabStrip_Drop">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                            <!-- Nav bar -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,3">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,4,0">
                                        <Button Command="{Binding RightPane.NavigateBackCommand}" Style="{StaticResource NavButton}" ToolTip="Back" AutomationProperties.Name="Back">
                                            <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding RightPane.NavigateForwardCommand}" Style="{StaticResource NavButton}" ToolTip="Forward" AutomationProperties.Name="Forward">
                                            <iconPacks:PackIconMaterial Kind="ChevronRight" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding RightPane.NavigateUpCommand}" Style="{StaticResource NavButton}" ToolTip="Up" AutomationProperties.Name="Up one level">
                                            <iconPacks:PackIconMaterial Kind="ArrowUp" Width="13" Height="13"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button x:Name="RightViewModeButton" Style="{StaticResource NavButton}" ToolTip="View Mode" Click="RightViewModeButton_Click" AutomationProperties.Name="View mode">
                                            <iconPacks:PackIconMaterial Kind="ViewList" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding RightPane.ToggleFilterCommand}" Style="{StaticResource NavButton}" ToolTip="Filter current folder (loaded items only)" AutomationProperties.Name="Toggle filter">
                                            <iconPacks:PackIconMaterial Kind="Filter" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding RightPane.TogglePreviewCommand}" Style="{StaticResource NavButton}" ToolTip="Preview (F8)" AutomationProperties.Name="Toggle preview pane">
                                            <iconPacks:PackIconMaterial Kind="Eye" Width="13" Height="13"/>
                                        </Button>
                                        <Button Command="{Binding RightPane.NavigateCommand}" Style="{StaticResource NavButton}" ToolTip="Refresh" Margin="4,0,0,0" AutomationProperties.Name="Refresh">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13"/>
                                        </Button>
                                    </StackPanel>
                                    <ctrl:BreadcrumbBar Path="{Binding RightPane.CurrentPath, Mode=TwoWay}"
                                                        NavigateCommand="{Binding RightPane.GoToPathCommand}"
                                                        VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <!-- Status bar -->
                            <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8,3">
                                <TextBlock Text="{Binding RightPane.StatusText}"
                                           Foreground="{DynamicResource SubTextFg}" FontSize="11"/>
                            </Border>
                            <!-- File list + preview -->
                            <Grid>
                                <Grid.Resources>
                                    <conv:BindingProxy x:Key="RightDcProxy" Data="{Binding}"/>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="{Binding Data.RightPane.ShowPreview, Source={StaticResource RightDcProxy}, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=4}"/>
                                    <ColumnDefinition Width="{Binding Data.RightPane.ShowPreview, Source={StaticResource RightDcProxy}, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=320}"
                                                      MinWidth="{Binding Data.RightPane.ShowPreview, Source={StaticResource RightDcProxy}, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter=200}"/>
                                </Grid.ColumnDefinitions>
                                <ListView x:Name="RightList" Grid.Column="0"
                                          Visibility="{Binding RightPane.ViewMode, Converter={StaticResource ViewModeToVisibilityConverter}, ConverterParameter=Details}"
                                          ItemsSource="{Binding RightPane.ItemsView}"
                                          SelectedItem="{Binding RightPane.SelectedItem, Mode=TwoWay}"
                                          Tag="{Binding RightPane}" SelectionMode="Extended"
                                          ContextMenu="{StaticResource PaneContextMenu}"
                                          Background="{DynamicResource PaneBg}" BorderThickness="0"
                                          MouseDoubleClick="RightList_MouseDoubleClick"
                                          PreviewMouseLeftButtonUp="RightList_PreviewMouseLeftButtonUp"
                                          GotFocus="RightList_GotFocus"
                                          SelectionChanged="RightList_SelectionChanged"
                                          ContextMenuOpening="RightList_ContextMenuOpening"
                                          GridViewColumnHeader.Click="PaneList_ColumnHeaderClick"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="PaneList_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="PaneList_PreviewMouseMove"
                                          DragOver="PaneList_DragOver"
                                          Drop="PaneList_Drop"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          KeyboardNavigation.TabNavigation="Once"
                                          KeyboardNavigation.DirectionalNavigation="Contained">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="32">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding ShellIcon}" Width="20" Height="20"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" Width="260">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <StackPanel Orientation="Vertical"
                                                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource FolderNameFg}"/>
                                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            </DataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                                    <Condition Binding="{Binding DataContext.IsSingleClickMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding RelativeSubPath}" FontSize="10"
                                                                       Foreground="{DynamicResource SubTextFg}"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,-2,0,0"
                                                                       ToolTip="{Binding FullPath}"
                                                                       Visibility="{Binding HasRelativeSubPath, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                            <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                     Background="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource AccentBrush}"
                                                                     BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                                                     FontSize="12.5" Padding="2,0" Margin="-3,0"
                                                                     IsVisibleChanged="RenameBox_IsVisibleChanged"
                                                                     PreviewKeyDown="RenameBox_PreviewKeyDown"
                                                                     LostFocus="RenameBox_LostFocus"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Type" Width="70">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="11"
                                                                   Foreground="{DynamicResource SubTextFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Size" Width="80">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                                   Foreground="{DynamicResource SubTextFg}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Modified" Width="140">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding LastWriteTimeLocal, StringFormat={}{0:yyyy-MM-dd  HH:mm}}"
                                                                   FontSize="11" Foreground="{DynamicResource SubTextFg}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <!-- Icon/List/Tiles view (right) -->
                                <ListBox x:Name="RightIconList" Grid.Column="0"
                                         Visibility="{Binding RightPane.ViewMode, Converter={StaticResource ViewModeNotEqualToVisibilityConverter}, ConverterParameter=Details}"
                                         ItemsSource="{Binding RightPane.ItemsView}"
                                         SelectedItem="{Binding RightPane.SelectedItem, Mode=TwoWay}"
                                         Tag="{Binding RightPane}" SelectionMode="Extended"
                                         ContextMenu="{StaticResource PaneContextMenu}"
                                         Background="{DynamicResource PaneBg}" BorderThickness="0"
                                         MouseDoubleClick="RightList_MouseDoubleClick"
                                         PreviewMouseLeftButtonUp="RightList_PreviewMouseLeftButtonUp"
                                         GotFocus="RightList_GotFocus"
                                         SelectionChanged="RightIconList_SelectionChanged"
                                         ContextMenuOpening="RightList_ContextMenuOpening"
                                         AllowDrop="True"
                                         PreviewMouseLeftButtonDown="PaneList_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="PaneList_PreviewMouseMove"
                                         DragOver="PaneList_DragOver"
                                         Drop="PaneList_Drop"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="ItemTemplate" Value="{StaticResource LargeIconItemTemplate}"/>
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RightPane.ViewMode}" Value="SmallIcons">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource SmallIconItemTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RightPane.ViewMode}" Value="List">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource ListItemTemplate}"/>
                                                    <Setter Property="ItemsPanel">
                                                        <Setter.Value>
                                                            <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RightPane.ViewMode}" Value="Tiles">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource TilesItemTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                </ListBox>
                                <!-- Preview pane (right) -->
                                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              Visibility="{Binding RightPane.ShowPreview, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Background="{DynamicResource BorderBrush}"/>
                                <Border Grid.Column="2"
                                        Visibility="{Binding RightPane.ShowPreview, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,1,0,0" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Reveal" Click="PreviewReveal_Click" Tag="Right"
                                                        Style="{StaticResource NavButton}" Width="Auto" Padding="8,3"
                                                        ToolTip="Reveal in Windows Explorer"
                                                        AutomationProperties.Name="Reveal in Windows Explorer"/>
                                                <Button Content="Properties" Click="PreviewProperties_Click" Tag="Right"
                                                        Style="{StaticResource NavButton}" Width="Auto" Padding="8,3" Margin="4,0,0,0"
                                                        ToolTip="Show native Windows properties dialog"
                                                        AutomationProperties.Name="Open native properties"/>
                                            </StackPanel>
                                        </Border>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="RightPreviewPanel" Margin="10"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <!-- Floating filter overlay (right) -->
                                <Border Grid.Column="0" Tag="{Binding RightPane}"
                                        Visibility="{Binding RightPane.IsFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,8,12,0" Padding="8,5"
                                        Background="{DynamicResource HeaderBg}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Effect="{StaticResource DialogShadow}">
                                    <DockPanel MinWidth="260">
                                        <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="Magnify" Width="12" Height="12"
                                                                    Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button DockPanel.Dock="Right" Command="{Binding RightPane.ClearFilterCommand}"
                                                Style="{StaticResource NavButton}" Width="20" Height="20" ToolTip="Clear filter (Esc)"
                                                AutomationProperties.Name="Clear filter">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="9" Height="9"/>
                                        </Button>
                                        <TextBox x:Name="RightFilterBox"
                                                 Text="{Binding RightPane.FilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontFamily="Cascadia Code,Consolas" FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 IsVisibleChanged="FilterBox_IsVisibleChanged"
                                                 PreviewKeyDown="FilterBox_PreviewKeyDown"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <!-- ROW 2: BOTTOM PANEL (Tabbed: Terminal / Git History) -->
                <Grid Grid.Row="2" Background="{DynamicResource AppBg}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="290" MinWidth="160"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Bottom-panel tab strip ── -->
                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource StatusBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <!-- Terminal / Git History top tabs -->
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <!-- Terminal tab -->
                                <Border MouseLeftButtonDown="BottomTab_Terminal_Click" Cursor="Hand"
                                        Padding="12,5" MinWidth="90">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Terminal">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Background" Value="{DynamicResource PaneBg}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="12" Height="12"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Terminal">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <TextBlock Text="Terminal" FontSize="11.5" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Terminal">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <!-- Git History tab -->
                                <Border MouseLeftButtonDown="BottomTab_GitHistory_Click" Cursor="Hand"
                                        Padding="12,5" MinWidth="90">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveBottomTab}" Value="GitHistory">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Background" Value="{DynamicResource PaneBg}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="SourceBranch" Width="12" Height="12"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="GitHistory">
                                                            <Setter Property="Foreground" Value="#F97316"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <TextBlock Text="Git History" FontSize="11.5" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="GitHistory">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Entry count badge -->
                                        <Border Background="{DynamicResource HeaderBg}" CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding GitHistory.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding GitHistory.Entries.Count}" FontSize="10"
                                                       Foreground="{DynamicResource SubTextFg}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <!-- Git (Source Control) tab -->
                                <Border MouseLeftButtonDown="BottomTab_Git_Click" Cursor="Hand"
                                        Padding="12,5" MinWidth="90">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Git">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Background" Value="{DynamicResource PaneBg}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="SourcePull" Width="12" Height="12"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Git">
                                                            <Setter Property="Foreground" Value="{DynamicResource DiffAddedFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <TextBlock Text="Git" FontSize="11.5" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Git">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Pending count badge -->
                                        <Border Background="{DynamicResource HeaderBg}" CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GitTab.IsGitRepo}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding GitTab.TotalCount}" FontSize="10"
                                                       Foreground="{DynamicResource SubTextFg}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ── Terminal tab strip + actions (inside top bar, right side) ── -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,0"
                                        DataContext="{Binding TerminalPanel}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ActiveBottomTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="Terminal">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <!-- Split buttons -->
                                <Button Command="{Binding SplitHorizontalCommand}" Style="{StaticResource NavButton}"
                                        Width="24" Height="22" ToolTip="Split Horizontal" Margin="2,0">
                                    <iconPacks:PackIconMaterial Kind="ArrowSplitVertical" Width="11" Height="11"/>
                                </Button>
                                <Button Command="{Binding SplitVerticalCommand}" Style="{StaticResource NavButton}"
                                        Width="24" Height="22" ToolTip="Split Vertical" Margin="0,0,4,0">
                                    <iconPacks:PackIconMaterial Kind="ArrowSplitHorizontal" Width="11" Height="11"/>
                                </Button>
                                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="2,4"/>
                                <!-- Add tab button -->
                                <Button Command="{Binding AddTabCommand}" Style="{StaticResource NavButton}"
                                        Width="24" Height="22" ToolTip="New Terminal Tab" Margin="2,0">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="10" Height="10"/>
                                </Button>
                            </StackPanel>

                            <!-- ── Terminal sub-tabs ── -->
                            <ItemsControl DataContext="{Binding TerminalPanel}" ItemsSource="{Binding Tabs}" Margin="8,0,0,0">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ActiveBottomTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="Terminal">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                                        <Border MinWidth="50" MaxWidth="140" Cursor="Hand"
                                                MouseLeftButtonDown="TerminalTab_Click"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PaneBg}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Tag="{Binding}" Click="TerminalTabClose_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Width="14" Height="14" Padding="2"
                                                        Margin="0,0,4,0" VerticalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" Padding="2">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <iconPacks:PackIconMaterial Kind="Close" Width="7" Height="7" Foreground="{DynamicResource SubTextFg}"/>
                                                </Button>
                                                <StackPanel Orientation="Horizontal" Margin="6,3">
                                                    <iconPacks:PackIconMaterial Kind="Console" Width="10" Height="10"
                                                        VerticalAlignment="Center" Margin="0,0,4,0"
                                                        Foreground="{Binding Shell, Converter={StaticResource ShellPromptColorConverter}}"/>
                                                    <TextBlock Text="{Binding Header}" FontSize="10.5" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource InactiveTextFg}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Git branch badge -->
                                                    <TextBlock Text="{Binding GitBranch}" FontSize="9" Margin="4,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding GitBranchInfo, Converter={StaticResource GitBranchColorConverter}}"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="60">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding GitBranch}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>

                    <!-- ── TERMINAL CONTENT (visible when Terminal tab active) ── -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource TerminalBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Terminal">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid DataContext="{Binding TerminalPanel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ── Main terminal output (active tab) ── -->
                            <ctrl:AnsiRichTextBox x:Name="TerminalOutput" Grid.Column="0" Grid.Row="0"
                                Segments="{Binding ActiveTab.OutputSegments}"
                                Background="{DynamicResource TerminalBg}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource TextFg}"
                                FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12.5"
                                BorderThickness="0" Padding="0"
                                VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>

                            <!-- ── Horizontal split splitter ── -->
                            <GridSplitter Grid.Column="1" Grid.Row="0" Width="4" HorizontalAlignment="Stretch"
                                          Visibility="{Binding SplitOrientation, Converter={StaticResource SplitActiveToVisibilityConverter}}"/>

                            <!-- ── Split pane output ── -->
                            <ctrl:AnsiRichTextBox Grid.Column="2" Grid.Row="0"
                                Segments="{Binding SplitTab.OutputSegments}"
                                Visibility="{Binding SplitOrientation, Converter={StaticResource SplitActiveToVisibilityConverter}}"
                                Background="{DynamicResource TerminalBg}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource TextFg}"
                                FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12.5"
                                BorderThickness="1,0,0,0" BorderBrush="{DynamicResource BorderBrush}"
                                Padding="0" MinWidth="200"
                                VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>

                            <!-- ── Ctrl+R History search overlay ── -->
                            <Border Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3"
                                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                    Visibility="{Binding ActiveTab.IsHistorySearchActive, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                                    Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Padding="10,6">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="(reverse-i-search)" FontSize="11"
                                               Foreground="{DynamicResource HistorySearchLabelFg}" VerticalAlignment="Center" Margin="0,0,8,0"
                                               FontFamily="Cascadia Code,Consolas"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding ActiveTab.HistorySearchResult, FallbackValue=''}"
                                               FontFamily="Cascadia Code,Consolas" FontSize="12"
                                               Foreground="{DynamicResource HistorySearchResultFg}" VerticalAlignment="Center" Margin="8,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBox x:Name="HistorySearchBox"
                                             Text="{Binding ActiveTab.HistorySearchText, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                                             Background="Transparent" BorderThickness="0,0,0,1"
                                             BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource AccentBrush}"
                                             FontFamily="Cascadia Code,Consolas" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             PreviewKeyDown="HistorySearchBox_PreviewKeyDown"
                                             TextChanged="HistorySearchBox_TextChanged"/>
                                </DockPanel>
                            </Border>

                            <!-- ── Split-pane command input (when split is active) ── -->
                            <Border Grid.Column="2" Grid.Row="1"
                                    Visibility="{Binding SplitOrientation, Converter={StaticResource SplitActiveToVisibilityConverter}}"
                                    Background="{DynamicResource TerminalBg}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,0" Padding="4,3">
                                <DockPanel DataContext="{Binding SplitTab}">
                                    <ComboBox DockPanel.Dock="Left"
                                              ItemsSource="{Binding DataContext.TerminalPanel.ShellKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Shell}"
                                              Width="70" Margin="0,0,4,0"
                                              FontFamily="Cascadia Code,Consolas" FontSize="10"
                                              BorderThickness="0" Background="{DynamicResource TerminalBg}"
                                              Foreground="{Binding Shell, Converter={StaticResource ShellPromptColorConverter}}"/>
                                    <Button DockPanel.Dock="Right"
                                            Content="{Binding IsRunning, Converter={StaticResource RunningToButtonTextConverter}}"
                                            Command="{Binding RunCommandCommand}"
                                            Style="{StaticResource RunButton}" Height="22" MinWidth="40" Margin="4,0,0,0"/>
                                    <TextBox Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0,0,0,1"
                                             BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource AccentBrush}"
                                             FontFamily="Cascadia Code,Consolas" FontSize="11"
                                             VerticalContentAlignment="Center" Padding="4,0">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding RunCommandCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── GIT HISTORY CONTENT (visible when GitHistory tab active) ── -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="{DynamicResource PaneBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveBottomTab}" Value="GitHistory">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid DataContext="{Binding GitHistory}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Commit list -->
                            <DockPanel Grid.Column="0">
                                <!-- Git history header bar -->
                                <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                        Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Command="{Binding CloseCommand}"
                                                Style="{StaticResource NavButton}" Width="22" Height="22" ToolTip="Close">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="9" Height="9"/>
                                        </Button>
                                        <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                                                Style="{StaticResource NavButton}" Width="22" Height="22" ToolTip="Refresh" Margin="0,0,2,0">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="10" Height="10"/>
                                        </Button>
                                        <!-- Branch selector (searchable dropdown) -->
                                        <Grid DockPanel.Dock="Right" Width="200" Margin="0,0,6,0"
                                              Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ToggleButton x:Name="BranchDropdownToggle"
                                                          IsChecked="{Binding IsBranchDropdownOpen, Mode=TwoWay}"
                                                          Background="{DynamicResource HeaderBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                          Foreground="{DynamicResource TextFg}"
                                                          HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
                                                          Padding="6,3" Cursor="Hand">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="2" Padding="{TemplateBinding Padding}"
                                                                SnapsToDevicePixels="True">
                                                            <DockPanel>
                                                                <Path DockPanel.Dock="Right" Data="M 0,0 L 4,4 L 8,0 Z"
                                                                      Fill="{DynamicResource SubTextFg}" Width="8" Height="4"
                                                                      VerticalAlignment="Center" Margin="4,0,2,0"/>
                                                                <TextBlock Text="{Binding SelectedBranch, FallbackValue='(none)'}"
                                                                           Foreground="{DynamicResource TextFg}"
                                                                           FontFamily="Cascadia Code,Consolas" FontSize="11"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                            </DockPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=BranchDropdownToggle}"
                                                   Placement="Bottom"
                                                   IsOpen="{Binding IsBranchDropdownOpen, Mode=TwoWay}"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Slide">
                                                <Border Background="{DynamicResource PaneBg}" BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="2"
                                                        MinWidth="220" MaxHeight="350" Margin="0,2,0,0"
                                                        SnapsToDevicePixels="True">
                                                    <DockPanel>
                                                        <!-- Search box -->
                                                        <Border DockPanel.Dock="Top" Padding="4">
                                                            <TextBox Text="{Binding BranchFilter, UpdateSourceTrigger=PropertyChanged}"
                                                                     FontFamily="Cascadia Code,Consolas" FontSize="11"
                                                                     Background="{DynamicResource TreeBg}" Foreground="{DynamicResource TextFg}"
                                                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                     Padding="6,4" CaretBrush="{DynamicResource TextFg}"
                                                                     Tag="Search branches…"/>
                                                        </Border>
                                                        <!-- Filtered branch list -->
                                                        <ListBox ItemsSource="{Binding FilteredBranches}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 MaxHeight="300">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="Padding" Value="8,4"/>
                                                                    <Setter Property="FontFamily" Value="Cascadia Code,Consolas"/>
                                                                    <Setter Property="FontSize" Value="11"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                                        Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsSelected" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="BranchItem_Click"/>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="SourceBranch" Width="13" Height="13"
                                                                    Foreground="#F97316" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>

                                <!-- Loading indicator -->
                                <Border DockPanel.Dock="Top" Height="2"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Background="{DynamicResource AccentBrush}" HorizontalAlignment="Stretch"/>
                                </Border>

                                <!-- Not a git repo message -->
                                <Border Visibility="{Binding IsGitRepo, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <iconPacks:PackIconMaterial Kind="SourceBranchRemove" Width="32" Height="32"
                                                                    Foreground="{DynamicResource SubTextFg}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <TextBlock Text="Not a Git repository" Foreground="{DynamicResource SubTextFg}"
                                                   FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Navigate to a Git repository to see history" Foreground="{DynamicResource SubTextFg}"
                                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Commit list -->
                                <ListView x:Name="GitHistoryList"
                                          ItemsSource="{Binding Entries}"
                                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                          Background="{DynamicResource PaneBg}" BorderThickness="0"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListView.View>
                                        <GridView>
                                            <!-- Graph/Avatar column -->
                                            <GridViewColumn Width="36">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="{DynamicResource GitAvatarBg}" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding AuthorInitial}" FontSize="11" FontWeight="Bold"
                                                                       Foreground="{DynamicResource GitAvatarFg}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <!-- Hash column -->
                                            <GridViewColumn Header="Hash" Width="75">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ShortHash}" FontFamily="Cascadia Code,Consolas" FontSize="11"
                                                                   Foreground="{DynamicResource HashFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <!-- Message column -->
                                            <GridViewColumn Header="Message" Width="380">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Subject}" FontSize="12"
                                                                   Foreground="{DynamicResource TextFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <!-- Author column -->
                                            <GridViewColumn Header="Author" Width="130">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding AuthorName}" FontSize="11"
                                                                   Foreground="{DynamicResource SubTextFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <!-- Date column -->
                                            <GridViewColumn Header="Date" Width="110">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RelativeDate}" FontSize="11"
                                                                   Foreground="{DynamicResource SubTextFg}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>

                            <!-- Commit diff pane (right side) -->
                            <Border Grid.Column="1" Width="420"
                                    Visibility="{Binding IsDiffVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                                <DockPanel>
                                    <!-- Header -->
                                    <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                            Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Command="{Binding CloseDiffCommand}"
                                                    Style="{StaticResource NavButton}" Width="20" Height="20" ToolTip="Close diff">
                                                <iconPacks:PackIconMaterial Kind="Close" Width="8" Height="8"/>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Command="{Binding CopyHashCommand}"
                                                    Style="{StaticResource NavButton}" Width="20" Height="20" ToolTip="Copy hash" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="9" Height="9"/>
                                            </Button>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center">
                                                <Run Text="Commit " FontWeight="SemiBold"/>
                                                <Run Text="{Binding SelectedEntry.ShortHash, Mode=OneWay, FallbackValue=''}"
                                                     Foreground="{DynamicResource HashFg}" FontFamily="Cascadia Code,Consolas"/>
                                                <Run Text=" — Double-click a file to compare" Foreground="{DynamicResource SubTextFg}" FontSize="10"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>

                                    <!-- Changed files list -->
                                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                            MaxHeight="180">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Top" Padding="8,4" Background="{DynamicResource PaneBg}">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource SubTextFg}">
                                                    <Run Text="Changed Files" FontWeight="SemiBold"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding ChangedFiles.Count, Mode=OneWay}"/>
                                                    <Run Text=")"/>
                                                </TextBlock>
                                            </Border>
                                            <ListView ItemsSource="{Binding ChangedFiles}"
                                                      Background="Transparent" BorderThickness="0"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      MouseDoubleClick="GitHistoryChangedFile_DoubleClick">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Padding" Value="6,2"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListViewItem">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelBg}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <!-- Status badge -->
                                                            <Border DockPanel.Dock="Left" Width="18" Height="16" CornerRadius="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                    Background="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource AppBg}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <!-- File name + directory -->
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Directory}" FontSize="10"
                                                                       Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                                       Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       FontFamily="Cascadia Code,Consolas"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </DockPanel>
                                    </Border>

                                    <!-- Diff content (full commit) -->
                                    <TextBox Text="{Binding CommitDiff, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                                             Background="{DynamicResource TreeBg}" Foreground="{DynamicResource SubTextFg}" CaretBrush="{DynamicResource SubTextFg}"
                                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11"
                                             BorderThickness="0" Padding="8,6"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap"/>
                                </DockPanel>
                            </Border>

                            <!-- Side-by-side file diff overlay (covers both columns) -->
                            <Border Grid.Column="0" Grid.ColumnSpan="2"
                                    Visibility="{Binding IsFileDiffOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource TreeBg}">
                                <DockPanel>
                                    <!-- Diff header -->
                                    <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                            Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Command="{Binding CloseFileDiffCommand}"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" ToolTip="Close diff">
                                                <iconPacks:PackIconMaterial Kind="Close" Width="9" Height="9"/>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Command="{Binding CopyHashCommand}"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" ToolTip="Copy hash" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="9" Height="9"/>
                                            </Button>
                                            <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="FileCompare" Width="13" Height="13"
                                                                        Foreground="#E2C04B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                                <Run Text="{Binding DiffFileName, Mode=OneWay}" Foreground="{DynamicResource TextFg}"
                                                     FontFamily="Cascadia Code,Consolas"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding SelectedEntry.ShortHash, Mode=OneWay, FallbackValue=''}"
                                                     Foreground="{DynamicResource HashFg}" FontFamily="Cascadia Code,Consolas"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>

                                    <!-- Side-by-side panels -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Old (parent commit) -->
                                        <DockPanel Grid.Column="0">
                                            <Border DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource DiffRemovedHeaderBg}">
                                                <TextBlock FontSize="10" Foreground="{DynamicResource DiffRemovedFg}" FontWeight="SemiBold">
                                                    <Run Text="Before"/>
                                                    <Run Text=" (parent commit)" FontWeight="Normal" Foreground="{DynamicResource DiffRemovedSubFg}"/>
                                                </TextBlock>
                                            </Border>
                                            <ctrl:DiffRichTextBox DiffLines="{Binding DiffOldLines}" SharedScrollBar="{Binding ElementName=FileDiffMiddleScroll}"/>
                                        </DockPanel>

                                        <!-- Middle scrollbar (scrolls both panels) -->
                                        <ScrollBar x:Name="FileDiffMiddleScroll" Grid.Column="1" Orientation="Vertical" Width="14"/>

                                        <!-- New (this commit) -->
                                        <DockPanel Grid.Column="2">
                                            <Border DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource DiffAddedHeaderBg}">
                                                <TextBlock FontSize="10" Foreground="{DynamicResource DiffAddedFg}" FontWeight="SemiBold">
                                                    <Run Text="After"/>
                                                    <Run Text=" (this commit)" FontWeight="Normal" Foreground="{DynamicResource DiffAddedSubFg}"/>
                                                </TextBlock>
                                            </Border>
                                            <ctrl:DiffRichTextBox DiffLines="{Binding DiffNewLines}" SharedScrollBar="{Binding ElementName=FileDiffMiddleScroll}"/>
                                        </DockPanel>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── GIT (SOURCE CONTROL) CONTENT (visible when Git tab active) ── -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="{DynamicResource PaneBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Git">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid DataContext="{Binding GitTab}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left panel: changes list -->
                            <DockPanel Grid.Column="0">
                                <!-- Git tab header bar -->
                                <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                        Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <!-- Close / Refresh -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Command="{Binding RefreshCommand}"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" ToolTip="Refresh" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="Refresh" Width="10" Height="10"/>
                                            </Button>
                                        </StackPanel>
                                        <!-- Action buttons -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,6,0">
                                            <Button Command="{Binding FetchCommand}" ToolTip="Fetch"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="CloudDownload" Width="10" Height="10"/>
                                            </Button>
                                            <Button Command="{Binding PullCommand}" ToolTip="Pull"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="ArrowDown" Width="10" Height="10"/>
                                            </Button>
                                            <Button Command="{Binding PushCommand}" ToolTip="Push"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="ArrowUp" Width="10" Height="10"/>
                                            </Button>
                                            <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,3"/>
                                            <Button Command="{Binding StashCommand}" ToolTip="Stash"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22" Margin="0,0,2,0">
                                                <iconPacks:PackIconMaterial Kind="PackageDown" Width="10" Height="10"/>
                                            </Button>
                                            <Button Command="{Binding StashPopCommand}" ToolTip="Stash Pop"
                                                    Style="{StaticResource NavButton}" Width="22" Height="22">
                                                <iconPacks:PackIconMaterial Kind="PackageUp" Width="10" Height="10"/>
                                            </Button>
                                        </StackPanel>
                                        <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="SourcePull" Width="13" Height="13"
                                                                    Foreground="{DynamicResource DiffAddedFg}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubTextFg}">
                                            <Run Text="Source Control"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding CurrentBranch, Mode=OneWay, FallbackValue=''}" Foreground="{DynamicResource HashFg}"
                                                 FontFamily="Cascadia Code,Consolas"/>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>

                                <!-- Loading indicator -->
                                <Border DockPanel.Dock="Top" Height="2"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Background="{DynamicResource AccentBrush}" HorizontalAlignment="Stretch"/>
                                </Border>

                                <!-- Status message bar -->
                                <Border DockPanel.Dock="Top" Padding="8,4" Background="{DynamicResource GitStatusBg}"
                                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Command="{Binding DismissStatusCommand}"
                                                Style="{StaticResource NavButton}" Width="16" Height="16">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="7" Height="7"/>
                                        </Button>
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource GitStatusFg}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   FontFamily="Cascadia Code,Consolas"/>
                                    </DockPanel>
                                </Border>

                                <!-- Commit message + button -->
                                <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource TreeBg}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Command="{Binding CommitCommand}"
                                                ToolTip="Commit staged changes (Ctrl+Enter)"
                                                Margin="6,0,0,0" Padding="10,4" VerticalAlignment="Top">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <iconPacks:PackIconMaterial Kind="Check" Width="10" Height="10"
                                                                                                    VerticalAlignment="Center" Margin="0,0,5,0"
                                                                                                    Foreground="White"/>
                                                                        <TextBlock Text="Commit" Foreground="White" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#1A8AD4"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextFg}"
                                                 CaretBrush="{DynamicResource TextFg}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 Padding="6,4" FontSize="12" AcceptsReturn="True"
                                                 MaxHeight="60" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Tag="Commit message…">
                                            <TextBox.InputBindings>
                                                <KeyBinding Gesture="Ctrl+Enter" Command="{Binding CommitCommand}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </DockPanel>
                                </Border>

                                <!-- Not a git repo message -->
                                <Border Visibility="{Binding IsGitRepo, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <iconPacks:PackIconMaterial Kind="SourceBranchRemove" Width="32" Height="32"
                                                                    Foreground="{DynamicResource SubTextFg}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <TextBlock Text="Not a Git repository" Foreground="{DynamicResource SubTextFg}"
                                                   FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- File lists (scrollable) -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <!-- ── STAGED FILES ── -->
                                        <Border Padding="8,4,8,2" Background="{DynamicResource PaneBg}">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Command="{Binding UnstageAllCommand}"
                                                        Style="{StaticResource NavButton}" Width="18" Height="18" ToolTip="Unstage All">
                                                    <iconPacks:PackIconMaterial Kind="MinusBox" Width="9" Height="9"/>
                                                </Button>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center">
                                                    <Run Text="Staged Changes" FontWeight="SemiBold"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding StagedCount, Mode=OneWay}"/>
                                                    <Run Text=")"/>
                                                </TextBlock>
                                            </DockPanel>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding StagedFiles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,3" Cursor="Hand"
                                                            MouseLeftButtonDown="GitFile_Click"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <DockPanel>
                                                            <!-- Unstage button -->
                                                            <Button DockPanel.Dock="Right" ToolTip="Unstage"
                                                                    Command="{Binding DataContext.UnstageFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource NavButton}" Width="18" Height="18" Margin="4,0,0,0">
                                                                <iconPacks:PackIconMaterial Kind="Minus" Width="8" Height="8"/>
                                                            </Button>
                                                            <!-- Status badge -->
                                                            <Border DockPanel.Dock="Left" Width="18" Height="16" CornerRadius="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                    Background="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource AppBg}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <!-- Directory -->
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Directory}" FontSize="10"
                                                                       Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <!-- File name -->
                                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                                       Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       FontFamily="Cascadia Code,Consolas"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- ── CHANGED (UNSTAGED) FILES ── -->
                                        <Border Padding="8,6,8,2" Background="{DynamicResource PaneBg}" Margin="0,2,0,0">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Button Command="{Binding DiscardAllCommand}"
                                                            Style="{StaticResource NavButton}" Width="18" Height="18" ToolTip="Discard All Changes" Margin="0,0,2,0">
                                                        <iconPacks:PackIconMaterial Kind="UndoVariant" Width="9" Height="9"/>
                                                    </Button>
                                                    <Button Command="{Binding StageAllCommand}"
                                                            Style="{StaticResource NavButton}" Width="18" Height="18" ToolTip="Stage All">
                                                        <iconPacks:PackIconMaterial Kind="PlusBox" Width="9" Height="9"/>
                                                    </Button>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center">
                                                    <Run Text="Changes" FontWeight="SemiBold"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding ChangedCount, Mode=OneWay}"/>
                                                    <Run Text=")"/>
                                                </TextBlock>
                                            </DockPanel>
                                        </Border>
                                        <ListBox x:Name="GitChangedFilesList"
                                                 ItemsSource="{Binding ChangedFiles}"
                                                 SelectionMode="Extended"
                                                 SelectionChanged="GitChangedFilesList_SelectionChanged"
                                                 Background="Transparent" BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelBg}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,3" Cursor="Hand"
                                                            MouseLeftButtonDown="GitFile_Click"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                        <DockPanel>
                                                            <!-- Action buttons -->
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,0,0,0">
                                                                <Button ToolTip="Discard Changes"
                                                                        Command="{Binding DataContext.DiscardFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource NavButton}" Width="18" Height="18">
                                                                    <iconPacks:PackIconMaterial Kind="UndoVariant" Width="8" Height="8"/>
                                                                </Button>
                                                                <Button ToolTip="Stage"
                                                                        Command="{Binding DataContext.StageFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource NavButton}" Width="18" Height="18">
                                                                    <iconPacks:PackIconMaterial Kind="Plus" Width="8" Height="8"/>
                                                                </Button>
                                                            </StackPanel>
                                                            <!-- Status badge -->
                                                            <Border DockPanel.Dock="Left" Width="18" Height="16" CornerRadius="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                    Background="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource AppBg}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <!-- Directory -->
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Directory}" FontSize="10"
                                                                       Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <!-- File name -->
                                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                                       Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       FontFamily="Cascadia Code,Consolas"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Discard Selected" Command="{Binding DiscardSelectedCommand}"
                                                              InputGestureText="Del">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="UndoVariant" Width="12" Height="12"
                                                                                       Background="Transparent" Foreground="{DynamicResource TextFg}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Discard All" Command="{Binding DiscardAllCommand}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="DeleteSweep" Width="12" Height="12"
                                                                                       Background="Transparent" Foreground="{DynamicResource TextFg}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Stage Selected" Click="GitStageSelected_Click">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12"
                                                                                       Background="Transparent" Foreground="{DynamicResource TextFg}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                        </ListBox>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>

                            <!-- Right panel: side-by-side diff viewer -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding IsDiffOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                                    MinWidth="500">
                                <DockPanel>
                                    <!-- Diff header -->
                                    <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                            Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Command="{Binding CloseDiffCommand}"
                                                    Style="{StaticResource NavButton}" Width="20" Height="20" ToolTip="Close diff">
                                                <iconPacks:PackIconMaterial Kind="Close" Width="8" Height="8"/>
                                            </Button>
                                            <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="FileCompare" Width="12" Height="12"
                                                                        Foreground="#E2C04B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"
                                                       FontFamily="Cascadia Code,Consolas" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding DiffFileName, Mode=OneWay}"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>

                                    <!-- Side-by-side diff panels -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Old (HEAD) -->
                                        <DockPanel Grid.Column="0">
                                            <Border DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource DiffRemovedHeaderBg}">
                                                <TextBlock Text="HEAD (old)" FontSize="10" Foreground="{DynamicResource DiffRemovedFg}" FontWeight="SemiBold"/>
                                            </Border>
                                            <ctrl:DiffRichTextBox DiffLines="{Binding DiffOldLines}" SharedScrollBar="{Binding ElementName=GitDiffMiddleScroll}"/>
                                        </DockPanel>

                                        <!-- Middle scrollbar (scrolls both panels) -->
                                        <ScrollBar x:Name="GitDiffMiddleScroll" Grid.Column="1" Orientation="Vertical" Width="14"/>

                                        <!-- New (Working Tree / Index) -->
                                        <DockPanel Grid.Column="2">
                                            <Border DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource DiffAddedHeaderBg}">
                                                <TextBlock Text="Working Tree (new)" FontSize="10" Foreground="{DynamicResource DiffAddedFg}" FontWeight="SemiBold"/>
                                            </Border>
                                            <ctrl:DiffRichTextBox DiffLines="{Binding DiffNewLines}" SharedScrollBar="{Binding ElementName=GitDiffMiddleScroll}"/>
                                        </DockPanel>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── Command input (only in Terminal tab) ── -->
                    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource TerminalBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="4,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveBottomTab}" Value="Terminal">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Popup x:Name="SuggestionPopup" PlacementTarget="{Binding ElementName=CommandInput}"
                                   Placement="RelativePoint" IsOpen="{Binding ShowSuggestions, Mode=TwoWay}"
                                   AllowsTransparency="True" StaysOpen="True" Focusable="False" PopupAnimation="None"
                                   Opened="SuggestionPopup_Opened">
                                <Border Background="{DynamicResource TreeBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="0,4" MinWidth="320" MaxWidth="720" MaxHeight="220">
                                    <ListBox x:Name="SuggestionList" ItemsSource="{Binding Suggestions}"
                                             SelectedIndex="{Binding SelectedSuggestionIndex, Mode=TwoWay}"
                                             Background="Transparent" BorderThickness="0" Focusable="False"
                                             MouseLeftButtonUp="SuggestionList_Click"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="8,3"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SelBg}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SuggestionItem}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <iconPacks:PackIconMaterial Grid.Column="0" Width="12" Height="12"
                                                        VerticalAlignment="Center"
                                                        Foreground="{Binding Kind, Converter={StaticResource SuggestionKindColorConverter}}">
                                                        <iconPacks:PackIconMaterial.Style>
                                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                                <Setter Property="Kind" Value="History"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="FileSystem">
                                                                        <Setter Property="Kind" Value="Folder"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="BangCommand">
                                                                        <Setter Property="Kind" Value="Flash"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="CliTool">
                                                                        <Setter Property="Kind" Value="Console"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </iconPacks:PackIconMaterial.Style>
                                                    </iconPacks:PackIconMaterial>
                                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding Text}" FontFamily="Cascadia Code,Consolas,Courier New"
                                                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{DynamicResource SubTextFg}"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Detail}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Detail}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Left" x:Name="ShellPicker"
                                          ItemsSource="{Binding ShellKinds}" SelectedItem="{Binding Shell}"
                                          Width="110" Margin="0,0,6,0"
                                          FontFamily="Cascadia Code,Consolas" FontSize="11.5"
                                          BorderThickness="0" Background="{DynamicResource TerminalBg}"
                                          Foreground="{Binding Shell, Converter={StaticResource ShellPromptColorConverter}}"/>
                                <Button DockPanel.Dock="Right"
                                        Content="{Binding IsRunning, Converter={StaticResource RunningToButtonTextConverter}}"
                                        Command="{Binding RunCommandCommand}"
                                        Style="{StaticResource RunButton}" Margin="6,0,0,0" Height="26"/>
                                <!-- Git branch badge in prompt -->
                                <Border DockPanel.Dock="Left" Margin="0,0,4,0" Padding="4,1" CornerRadius="3"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding TerminalPanel.ActiveTab.GitBranch, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource GitStatusBg}"/>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="SourceBranch" Width="10" Height="10"
                                            VerticalAlignment="Center" Margin="0,0,3,0"
                                            Foreground="{Binding TerminalPanel.ActiveTab.GitBranchInfo, Converter={StaticResource GitBranchColorConverter}}"/>
                                        <TextBlock Text="{Binding TerminalPanel.ActiveTab.GitBranchInfo, Converter={StaticResource GitBranchInfoToStringConverter}}"
                                                   FontFamily="Cascadia Code,Consolas" FontSize="10.5"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding TerminalPanel.ActiveTab.GitBranchInfo, Converter={StaticResource GitBranchColorConverter}}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="PromptLabel" Text="{Binding TerminalPrompt}"
                                           Foreground="{Binding Shell, Converter={StaticResource ShellPromptColorConverter}}"
                                           FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12.5" FontWeight="Bold"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420" Margin="0,0,4,0"/>
                                <Grid x:Name="CommandInputHost">
                                    <TextBlock x:Name="GhostTextBlock" Text="{Binding InlineSuggestion}"
                                               FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12.5"
                                               Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Padding="4,0"
                                               IsHitTestVisible="False" TextTrimming="CharacterEllipsis"/>
                                    <TextBox x:Name="CommandInput"
                                             Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0,0,0,1"
                                             BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextFg}" CaretBrush="{DynamicResource AccentBrush}"
                                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12.5"
                                             VerticalContentAlignment="Center" Padding="4,0"
                                             PreviewKeyDown="CommandInput_PreviewKeyDown"
                                             TextChanged="CommandInput_TextChanged">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding RunCommandCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- ── GridSplitter between main content and history sidebar ── -->
                    <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- ── History sidebar (column 2) ── -->
                    <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                            Background="{DynamicResource AppBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <!-- Tab strip: History / Favorites -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                    Padding="4,3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Border MouseLeftButtonDown="HistorySidebarTab_History_Click" Cursor="Hand"
                                            Padding="8,3" CornerRadius="3" Margin="0,0,2,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="History">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="History"
                                                                        Width="12" Height="12" Margin="0,0,5,0"
                                                                        Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                                            <TextBlock Text="History" FontSize="11" FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="History">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Border MouseLeftButtonDown="HistorySidebarTab_Favorites_Click" Cursor="Hand"
                                            Padding="8,3" CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="Favorites">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Star"
                                                                        Width="12" Height="12" Margin="0,0,5,0"
                                                                        Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Favorites" FontSize="11" FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextFg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="Favorites">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <!-- Filter box -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}"
                                    Padding="6,3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <TextBox Text="{Binding HistoryFilterText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11.5" VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Escape" Command="{Binding ClearHistoryFilterCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Border>
                            <!-- History / Favorites lists (stacked in a Grid so both can fill) -->
                            <Grid>
                            <!-- History list (visible when History tab active) -->
                            <ListBox x:Name="HistoryList" ItemsSource="{Binding HistoryView}"
                                     Background="{DynamicResource AppBg}" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="HistoryList_MouseDoubleClick">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="Favorites">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Toggle Favorite" Click="HistoryItem_ToggleFavorite_Click"
                                                              Tag="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                    Background="{Binding ExitCode, Converter={StaticResource ExitCodeBrushConverter}}"
                                                    Margin="0,3"/>
                                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="6,0,0,0">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Duration, Converter={StaticResource DurationToStringConverter}}"
                                                               FontSize="10" Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Duration}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Command}"
                                                               FontFamily="Cascadia Code,Consolas" FontSize="11.5"
                                                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFg}"/>
                                                </DockPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="{DynamicResource SubTextFg}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value=""/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ExitCode}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding WorkingDirectory}" FontSize="10.5"
                                                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SubTextFg}" Margin="0,1,0,0"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <!-- Favorite star indicator -->
                                            <iconPacks:PackIconMaterial Grid.Column="2" Kind="Star"
                                                                        Width="10" Height="10" Margin="4,0,2,0"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#FFD700">
                                                <iconPacks:PackIconMaterial.Style>
                                                    <Style TargetType="iconPacks:PackIconMaterial">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterial.Style>
                                            </iconPacks:PackIconMaterial>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <!-- Favorites list (visible when Favorites tab active) -->
                            <ListBox x:Name="FavoritesList" ItemsSource="{Binding FavoritesView}"
                                     Background="{DynamicResource AppBg}" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="FavoritesList_MouseDoubleClick">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveHistorySidebarTab}" Value="Favorites">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Remove from Favorites" Click="HistoryItem_ToggleFavorite_Click"
                                                              Tag="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                    Background="{Binding ExitCode, Converter={StaticResource ExitCodeBrushConverter}}"
                                                    Margin="0,3"/>
                                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="6,0,0,0">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Duration, Converter={StaticResource DurationToStringConverter}}"
                                                               FontSize="10" Foreground="{DynamicResource SubTextFg}" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Duration}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Command}"
                                                               FontFamily="Cascadia Code,Consolas" FontSize="11.5"
                                                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFg}"/>
                                                </DockPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="{DynamicResource SubTextFg}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value=""/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ExitCode}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding WorkingDirectory}" FontSize="10.5"
                                                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SubTextFg}" Margin="0,1,0,0"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- ══════════════ COMMAND PALETTE OVERLAY ══════════════ -->
    <Grid x:Name="CommandPaletteOverlay"
          Visibility="{Binding CommandPalette.IsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
          Panel.ZIndex="9998"
          Background="#40000000"
          MouseDown="CommandPalette_BackdropClick">

        <!-- Centered palette card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,80,0,0"
                Width="560" MaxHeight="480"
                Background="{DynamicResource PaneBg}"
                BorderBrush="{DynamicResource ActivePaneBorder}"
                BorderThickness="1"
                CornerRadius="8"
                MouseDown="CommandPalette_CardMouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search input -->
                <Border Grid.Row="0" Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="8,8,0,0" Padding="12,10">
                    <DockPanel>
                        <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="Magnify"
                            Width="16" Height="16" Foreground="{DynamicResource SubTextFg}"
                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="PaletteSearchBox"
                                 Text="{Binding CommandPalette.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextFg}"
                                 FontSize="14" FontFamily="Segoe UI"
                                 CaretBrush="{DynamicResource TextFg}"
                                 VerticalAlignment="Center"
                                 PreviewKeyDown="PaletteSearchBox_PreviewKeyDown"/>
                    </DockPanel>
                </Border>

                <!-- Category hint -->
                <Border Grid.Row="1" Background="{DynamicResource HeaderBg}"
                        Padding="12,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock FontSize="10.5" Foreground="{DynamicResource SubTextFg}">
                        <Run Text="↑↓ Navigate"/>
                        <Run Text="  "/>
                        <Run Text="Enter Select"/>
                        <Run Text="  "/>
                        <Run Text="Esc Close"/>
                    </TextBlock>
                </Border>

                <!-- Command list -->
                <ListBox Grid.Row="2" x:Name="PaletteList"
                         ItemsSource="{Binding CommandPalette.FilteredCommands}"
                         SelectedIndex="{Binding CommandPalette.SelectedIndex, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         MouseDoubleClick="PaletteList_MouseDoubleClick"
                         PreviewMouseLeftButtonUp="PaletteList_MouseClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,7"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelBg}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PaletteItemViewModel}">
                            <DockPanel>
                                <!-- Shortcut badge on right -->
                                <Border DockPanel.Dock="Right" VerticalAlignment="Center"
                                        Visibility="{Binding Shortcut, Converter={StaticResource NullToVisibilityConverter}}"
                                        Background="{DynamicResource HeaderBg}"
                                        CornerRadius="3" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Shortcut}" FontSize="10.5"
                                                FontFamily="Consolas"
                                                Foreground="{DynamicResource SubTextFg}"/>
                                </Border>
                                <!-- Category + Icon + Name -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource ButtonBg}" CornerRadius="3"
                                            Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                    Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                Foreground="{DynamicResource TextFg}"
                                                VerticalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>

    <!-- ══════════════ TOAST NOTIFICATIONS OVERLAY ══════════════ -->
    <ItemsControl x:Name="ToastHost"
                  ItemsSource="{Binding Source={x:Static svc:NotificationService.Instance}, Path=Notifications}"
                  IsHitTestVisible="True"
                  VerticalAlignment="Top" HorizontalAlignment="Right"
                  Margin="0,8,16,0"
                  Panel.ZIndex="9999">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type svc:NotificationItem}">
                <Border x:Name="ToastBorder" Margin="0,0,0,6" CornerRadius="6"
                        MinWidth="300" MaxWidth="380"
                        Background="{DynamicResource PaneBg}"
                        BorderThickness="1,1,1,1"
                        BorderBrush="{Binding Type, Converter={StaticResource NotificationTypeToBrushConverter}}"
                        Opacity="0"
                        RenderTransformOrigin="1,0">
                    <Border.RenderTransform>
                        <TranslateTransform X="40"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.4" Color="Black" Direction="270"/>
                    </Border.Effect>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource ToastEase}"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="40" To="0" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource ToastEase}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <DockPanel Margin="12,10">
                        <!-- Accent stripe icon -->
                        <Border DockPanel.Dock="Left" Width="4" CornerRadius="2" Margin="0,0,10,0"
                                Background="{Binding Type, Converter={StaticResource NotificationTypeToBrushConverter}}"/>
                        <!-- Dismiss button -->
                        <Button DockPanel.Dock="Right" VerticalAlignment="Top" Margin="8,0,0,0"
                                Cursor="Hand" Click="ToastDismiss_Click" Tag="{Binding}"
                                Background="Transparent" BorderThickness="0" Padding="2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="2">
                                        <iconPacks:PackIconMaterial x:Name="DismissIcon" Kind="Close" Width="12" Height="12"
                                                                    Foreground="{DynamicResource SubTextFg}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DismissIcon" Property="Foreground" Value="{DynamicResource TextFg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Content -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFg}" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Title}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubTextFg}" Margin="0,2,0,0"
                                       MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Grid>
</Window>

