<Window x:Class="Nexplorer.App.SpaceRadarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Nexplorer.App.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Space Radar — Disk Usage Treemap" Width="1100" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextFg}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBg}" Padding="12,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ChartTree" Width="20" Height="20"
                        Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="Space Radar" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton" Click="Back_Click" ToolTip="Go back (Backspace)"
                            Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                            BorderThickness="0" Padding="8,4" Margin="0,0,4,0" Cursor="Hand"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="12" Height="12"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Back" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RescanButton" Click="Rescan_Click" ToolTip="Rescan (F5)"
                            Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                            BorderThickness="0" Padding="8,4" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="12" Height="12"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Rescan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="BreadcrumbText" VerticalAlignment="Center" Margin="20,0,10,0"
                           FontSize="12" Foreground="{DynamicResource SubTextFg}" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Row 1: Progress bar (visible during scan) -->
        <Border x:Name="ProgressPanel" Grid.Row="1" Background="{DynamicResource HeaderBg}"
                Padding="12,6" Visibility="Visible">
            <DockPanel>
                <TextBlock x:Name="ProgressText" DockPanel.Dock="Left" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource SubTextFg}">
                    Scanning...
                </TextBlock>
                <ProgressBar x:Name="ScanProgress" DockPanel.Dock="Right" Height="4"
                             IsIndeterminate="True" Margin="12,0,0,0"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource InputBg}"/>
            </DockPanel>
        </Border>

        <!-- Row 2: Treemap area -->
        <Border Grid.Row="2" Background="{DynamicResource PaneBg}" Margin="2">
            <Grid>
                <ctrl:TreemapPanel x:Name="TreemapHost" Margin="1"/>
                <!-- Hover tooltip overlay -->
                <Border x:Name="TooltipOverlay" Background="#DD1C1C1C" CornerRadius="6"
                        Padding="12,8" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="16,16,0,0" Visibility="Collapsed" IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock x:Name="TipName" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFg}" TextTrimming="CharacterEllipsis"
                                   MaxWidth="400"/>
                        <TextBlock x:Name="TipSize" FontSize="12"
                                   Foreground="{DynamicResource SubTextFg}" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TipPercent" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TipChildren" FontSize="11"
                                   Foreground="{DynamicResource SubTextFg}" Margin="0,2,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
                <!-- Empty state -->
                <TextBlock x:Name="EmptyLabel" Text="No data to display" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource InactiveTextFg}" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Row 3: Status bar -->
        <Border Grid.Row="3" Background="{DynamicResource StatusBg}" Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="StatusLeft" DockPanel.Dock="Left" FontSize="11"
                           Foreground="{DynamicResource SubTextFg}"/>
                <TextBlock x:Name="StatusRight" DockPanel.Dock="Right" FontSize="11"
                           HorizontalAlignment="Right" Foreground="{DynamicResource SubTextFg}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
