<Window x:Class="Nexplorer.App.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        MaxWidth="460" MinWidth="320"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="{DynamicResource TextFg}">
    <Border Background="{DynamicResource PaneBg}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="0" Margin="16"
            Effect="{DynamicResource DialogShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}" CornerRadius="8,8,0,0"
                    Padding="16,12" MouseLeftButtonDown="TitleBar_MouseDown">
                <DockPanel>
                    <iconPacks:PackIconMaterial x:Name="DialogIcon" Kind="AlertCircleOutline"
                                                Width="18" Height="18" Foreground="#F59E0B"
                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleText" Text="Confirm" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFg}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Message -->
            <Border Grid.Row="1" Padding="20,16">
                <TextBlock x:Name="MessageText" Text="" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFg}" FontSize="13"
                           LineHeight="20" MaxWidth="400"/>
            </Border>

            <!-- Buttons -->
            <Border Grid.Row="2" Padding="16,8,16,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="NoBtn" Content="No" Click="No_Click" IsCancel="True"
                            MinWidth="80" Padding="12,7"
                            FontSize="12.5" Cursor="Hand"
                            Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextFg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="YesBtn" Content="Yes" Click="Yes_Click" IsDefault="True"
                            MinWidth="80" Padding="12,7" Margin="10,0,0,0"
                            FontSize="12.5" Cursor="Hand"
                            Foreground="White" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource AccentBrush}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
